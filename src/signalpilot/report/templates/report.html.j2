<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SignalPilot RCA Report – {{ analysis.namespace }}</title>
  <style>
    /* Minimal placeholder styles – full design TBD */
    body { font-family: system-ui, sans-serif; max-width: 960px; margin: 2rem auto; padding: 0 1rem; }
    h1 { color: #1a1a2e; }
    .finding { border-left: 4px solid #e63946; padding: 1rem; margin: 1rem 0; background: #fff8f8; }
    .finding.high { border-color: #f4a261; }
    .finding.medium { border-color: #e9c46a; }
    .finding.low { border-color: #2a9d8f; }
    pre { background: #f1f3f5; padding: 0.75rem; border-radius: 4px; overflow-x: auto; }
  </style>
</head>
<body>
  <h1>SignalPilot RCA Report</h1>
  <p><strong>Namespace:</strong> {{ analysis.namespace }}</p>
  <p><strong>Analysis time:</strong> {{ analysis.ts }}</p>
  <p><strong>Sources used:</strong> {{ analysis.sources_used | join(", ") }}</p>

  <h2>Summary</h2>
  <p>{{ analysis.narrative }}</p>

  <h2>Findings ({{ analysis.findings | length }})</h2>
  {% for finding in analysis.findings %}
  <div class="finding {{ finding.severity.value }}">
    <h3>[{{ finding.severity.value | upper }}] {{ finding.title }}</h3>
    <p>Confidence: {{ "%.0f" | format(finding.confidence * 100) }}% | Blast radius: {{ "%.0f" | format(finding.blast_radius * 100) }}%</p>
    <p>{{ finding.explanation }}</p>
    {% if finding.fixes %}
    <h4>Recommended fixes</h4>
    {% for fix in finding.fixes %}
    <p><strong>{{ fix.description }}</strong></p>
    {% if fix.kubectl_snippet %}
    <pre>{{ fix.kubectl_snippet }}</pre>
    {% endif %}
    {% endfor %}
    {% endif %}
  </div>
  {% endfor %}
</body>
</html>
