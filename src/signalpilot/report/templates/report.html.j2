<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SignalPilot RCA Report — {{ analysis.namespace }}</title>
<style>
/* ── PerfSage brand tokens ──────────────────────────────────────────────── */
:root {
  --navy:        #0D1F3C;
  --navy-mid:    #1A3A5C;
  --navy-light:  #1E4D7A;
  --bg:          #F4F1ED;
  --surface:     #FFFFFF;
  --border:      #E4E0D8;
  --border-md:   #CCC8BF;
  --text:        #1A1A2E;
  --text-muted:  #64748B;
  --text-light:  #94A3B8;

  --critical:    #DC2626; --critical-bg: #FEF2F2; --critical-bd: #FECACA;
  --high:        #EA580C; --high-bg:     #FFF7ED; --high-bd:     #FED7AA;
  --medium:      #D97706; --medium-bg:   #FFFBEB; --medium-bd:   #FDE68A;
  --low:         #059669; --low-bg:      #F0FDF4; --low-bd:      #A7F3D0;
  --info:        #2563EB; --info-bg:     #EFF6FF; --info-bd:     #BFDBFE;

  --shadow-sm:   0 1px 3px rgba(0,0,0,.07), 0 2px 8px rgba(0,0,0,.05);
  --shadow-md:   0 4px 8px rgba(0,0,0,.08), 0 12px 24px rgba(0,0,0,.06);
  --radius:      12px;
  --mono:        'SFMono-Regular', Consolas, 'Fira Mono', monospace;
}

/* ── Reset ──────────────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 15px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ── HEADER ─────────────────────────────────────────────────────────────── */
.report-header {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 55%, var(--navy-light) 100%);
  color: #fff;
}
.header-top {
  max-width: 1200px;
  margin: 0 auto;
  padding: 1.75rem 2rem 1.25rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}
.brand {
  display: flex;
  align-items: center;
  gap: 1rem;
}
.brand-logo {
  width: 48px;
  height: 48px;
  border-radius: 10px;
  flex-shrink: 0;
  background: rgba(255,255,255,.12);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.brand-logo img { width: 100%; height: 100%; object-fit: contain; }
.brand-text-wrap {}
.brand-eyebrow {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: rgba(255,255,255,.55);
}
.report-title {
  font-size: 1.45rem;
  font-weight: 800;
  color: #fff;
  line-height: 1.1;
}
.header-meta-block {
  text-align: right;
  font-size: 0.78rem;
  color: rgba(255,255,255,.55);
  line-height: 1.9;
}
.header-meta-block strong { color: rgba(255,255,255,.9); font-weight: 600; }

/* Severity + source pills row */
.header-pills {
  max-width: 1200px;
  margin: 0 auto;
  padding: .75rem 2rem 1.25rem;
  display: flex;
  align-items: center;
  gap: .6rem;
  flex-wrap: wrap;
}
.pill-label {
  font-size: .65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: rgba(255,255,255,.4);
  margin-right: .25rem;
}
.sev-pill {
  display: inline-flex;
  align-items: center;
  gap: .35rem;
  background: rgba(255,255,255,.1);
  border: 1px solid rgba(255,255,255,.18);
  border-radius: 2rem;
  padding: .22rem .7rem;
  font-size: .75rem;
  font-weight: 600;
  color: #fff;
}
.sev-pill .dot {
  width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
}
.dot-critical { background: #FC8181; }
.dot-high     { background: #F6AD55; }
.dot-medium   { background: #F6E05E; }
.dot-low      { background: #68D391; }
.sources-wrap {
  margin-left: auto;
  display: flex;
  gap: .4rem;
  flex-wrap: wrap;
  align-items: center;
}
.src-pill {
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.14);
  border-radius: 5px;
  padding: .15rem .55rem;
  font-size: .68rem;
  color: rgba(255,255,255,.65);
  font-family: var(--mono);
}

/* ── MAIN CONTAINER ─────────────────────────────────────────────────────── */
.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem;
}

/* ── ALERT BANNER ───────────────────────────────────────────────────────── */
.alert-banner {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 1.25rem 1.5rem;
  border-radius: var(--radius);
  margin-bottom: 2rem;
  box-shadow: var(--shadow-sm);
}
.alert-banner.critical { background: var(--critical-bg); border: 1.5px solid var(--critical-bd); }
.alert-banner.high     { background: var(--high-bg);     border: 1.5px solid var(--high-bd); }
.alert-banner.medium   { background: var(--medium-bg);   border: 1.5px solid var(--medium-bd); }
.alert-banner.low      { background: var(--low-bg);      border: 1.5px solid var(--low-bd); }
.alert-banner.healthy  { background: var(--low-bg);      border: 1.5px solid var(--low-bd); }
.alert-icon { font-size: 2rem; line-height: 1; flex-shrink: 0; margin-top: .1rem; }
.alert-body { flex: 1; min-width: 0; }
.alert-label {
  font-size: .65rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .1em;
  margin-bottom: .3rem;
}
.alert-label.critical { color: var(--critical); }
.alert-label.high     { color: var(--high); }
.alert-label.medium   { color: var(--medium); }
.alert-label.healthy  { color: var(--low); }
.alert-headline { font-size: 1.05rem; font-weight: 700; color: var(--text); margin-bottom: .35rem; }
.alert-desc { font-size: .88rem; color: var(--text-muted); line-height: 1.6; }

/* ── KPI GRID ───────────────────────────────────────────────────────────── */
.kpi-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1rem;
  margin-bottom: 2rem;
}
@media (max-width: 900px) { .kpi-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 600px) { .kpi-grid { grid-template-columns: repeat(2, 1fr); } }
.kpi-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.25rem 1rem 1rem;
  text-align: center;
  box-shadow: var(--shadow-sm);
  transition: transform .15s, box-shadow .15s;
}
.kpi-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
.kpi-icon { font-size: 1.5rem; margin-bottom: .3rem; }
.kpi-num { font-size: 2.25rem; font-weight: 800; line-height: 1; }
.kpi-num.c-critical { color: var(--critical); }
.kpi-num.c-high     { color: var(--high); }
.kpi-num.c-medium   { color: var(--medium); }
.kpi-num.c-navy     { color: var(--navy); }
.kpi-num.c-purple   { color: #7C3AED; }
.kpi-label {
  font-size: .65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: var(--text-muted);
  margin-top: .35rem;
}

/* ── NARRATIVE ──────────────────────────────────────────────────────────── */
.narrative-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-left: 4px solid var(--navy);
  border-radius: var(--radius);
  padding: 1.4rem 1.5rem;
  margin-bottom: 2rem;
  box-shadow: var(--shadow-sm);
  font-size: .9rem;
  color: var(--text);
  line-height: 1.75;
}
.narrative-card p + p { margin-top: .65rem; }

/* ── SECTION HEADING ────────────────────────────────────────────────────── */
.section-heading {
  display: flex;
  align-items: center;
  gap: .5rem;
  font-size: .7rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .12em;
  color: var(--text-muted);
  margin-bottom: 1rem;
  padding-bottom: .6rem;
  border-bottom: 1px solid var(--border);
}

/* ── DEPLOY CHANGE CARD ─────────────────────────────────────────────────── */
.deploy-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.5rem;
  margin-bottom: 2rem;
  box-shadow: var(--shadow-sm);
}
.deploy-header-row {
  display: flex;
  align-items: center;
  gap: .75rem;
  margin-bottom: 1.1rem;
}
.deploy-name-badge {
  background: var(--navy);
  color: #fff;
  border-radius: 6px;
  padding: .3rem .8rem;
  font-size: .8rem;
  font-weight: 700;
  font-family: var(--mono);
}
.deploy-rev-range {
  font-size: .85rem;
  color: var(--text-muted);
  font-family: var(--mono);
}
.deploy-rev-range strong { color: var(--navy); }
.diff-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: .6rem;
  margin-bottom: 1rem;
}
@media (max-width: 700px) { .diff-grid { grid-template-columns: 1fr; } }
.diff-cell {
  border-radius: 7px;
  padding: .6rem .9rem;
  font-family: var(--mono);
  font-size: .78rem;
  line-height: 1.5;
}
.diff-before { background: #FEF2F2; color: #991B1B; border: 1px solid #FECACA; }
.diff-after  { background: #F0FDF4; color: #166534; border: 1px solid #BBF7D0; }
.diff-field-label {
  font-size: .6rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .06em;
  opacity: .6;
  margin-bottom: .2rem;
}
.commit-row {
  display: flex;
  align-items: flex-start;
  gap: .75rem;
  padding: .75rem 1rem;
  background: #FFFBEB;
  border: 1px solid #FDE68A;
  border-radius: 8px;
  margin-top: .6rem;
}
.commit-sha {
  background: #F59E0B;
  color: #fff;
  font-family: var(--mono);
  font-size: .72rem;
  font-weight: 800;
  padding: .15rem .5rem;
  border-radius: 4px;
  flex-shrink: 0;
}
.commit-msg { font-size: .84rem; color: var(--text); flex: 1; }
.commit-author { font-size: .72rem; color: var(--text-muted); margin-top: .15rem; }

/* ── FINDING CARDS ──────────────────────────────────────────────────────── */
.finding-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 1.1rem;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  transition: box-shadow .2s;
}
.finding-card:hover { box-shadow: var(--shadow-md); }
.finding-card.sev-critical { border-left: 4px solid var(--critical); }
.finding-card.sev-high     { border-left: 4px solid var(--high); }
.finding-card.sev-medium   { border-left: 4px solid var(--medium); }
.finding-card.sev-low      { border-left: 4px solid var(--low); }
.finding-card.sev-info     { border-left: 4px solid var(--info); }

/* Header row */
.finding-header {
  display: flex;
  align-items: center;
  gap: .875rem;
  padding: 1.05rem 1.5rem;
  cursor: pointer;
  user-select: none;
  transition: background .15s;
}
.finding-header:hover { background: #FAFAF8; }

.sev-badge {
  display: inline-flex;
  align-items: center;
  gap: .3rem;
  padding: .22rem .7rem;
  border-radius: 2rem;
  font-size: .68rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .06em;
  flex-shrink: 0;
}
.sev-badge.critical { background: var(--critical-bg); color: var(--critical); border: 1px solid var(--critical-bd); }
.sev-badge.high     { background: var(--high-bg);     color: var(--high);     border: 1px solid var(--high-bd); }
.sev-badge.medium   { background: var(--medium-bg);   color: var(--medium);   border: 1px solid var(--medium-bd); }
.sev-badge.low      { background: var(--low-bg);      color: var(--low);      border: 1px solid var(--low-bd); }
.sev-badge.info     { background: var(--info-bg);     color: var(--info);     border: 1px solid var(--info-bd); }

.finding-title-wrap { flex: 1; min-width: 0; }
.finding-title { font-size: .95rem; font-weight: 700; color: var(--text); line-height: 1.3; }
.finding-target-line {
  font-size: .72rem;
  color: var(--text-muted);
  font-family: var(--mono);
  margin-top: .15rem;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.finding-right {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-shrink: 0;
}
.conf-wrap { text-align: right; }
.conf-bar-outer {
  width: 72px;
  height: 5px;
  background: var(--border);
  border-radius: 3px;
  overflow: hidden;
  margin-left: auto;
}
.conf-bar-inner { height: 100%; border-radius: 3px; background: var(--navy); }
.conf-pct { font-size: .72rem; font-weight: 800; color: var(--navy); margin-top: .2rem; }
.conf-label { font-size: .6rem; color: var(--text-light); text-transform: uppercase; letter-spacing: .05em; }
.chevron { color: var(--text-light); font-size: .85rem; transition: transform .2s; flex-shrink: 0; }
.chevron.open { transform: rotate(180deg); }

/* Body */
.finding-body { display: none; border-top: 1px solid var(--border); }
.finding-body.open { display: block; }
.finding-body-inner { padding: 1.4rem 1.5rem; }

.explanation-block {
  font-size: .88rem;
  color: var(--text);
  line-height: 1.75;
  background: #F8F6F2;
  border-left: 3px solid var(--border-md);
  border-radius: 0 8px 8px 0;
  padding: .9rem 1.2rem;
  margin-bottom: 1.4rem;
}

/* Two-column: fixes | evidence */
.finding-cols {
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  gap: 1.5rem;
}
@media (max-width: 820px) { .finding-cols { grid-template-columns: 1fr; } }

.col-title {
  font-size: .65rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: var(--text-muted);
  margin-bottom: .75rem;
  display: flex;
  align-items: center;
  gap: .4rem;
}

/* Fix items */
.fix-item {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: .9rem 1rem;
  margin-bottom: .7rem;
}
.fix-step-row {
  display: flex;
  align-items: flex-start;
  gap: .55rem;
  margin-bottom: .5rem;
}
.fix-num {
  min-width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--navy);
  color: #fff;
  font-size: .63rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: .15rem;
}
.fix-desc { font-size: .86rem; font-weight: 500; color: var(--text); flex: 1; line-height: 1.4; }
.fix-change-row {
  display: flex;
  align-items: center;
  gap: .5rem;
  font-size: .75rem;
  margin-bottom: .5rem;
}
.val-before { background: #FEF2F2; color: #991B1B; padding: .1rem .45rem; border-radius: 4px; font-family: var(--mono); }
.val-arrow  { color: var(--text-muted); }
.val-after  { background: #F0FDF4; color: #166534; padding: .1rem .45rem; border-radius: 4px; font-family: var(--mono); }
.fix-code-wrap { position: relative; margin-top: .45rem; }
.fix-code {
  background: #1E293B;
  color: #94EFD8;
  font-family: var(--mono);
  font-size: .76rem;
  padding: .7rem 3rem .7rem .85rem;
  border-radius: 7px;
  white-space: pre-wrap;
  word-break: break-all;
  line-height: 1.55;
}
.copy-btn {
  position: absolute;
  top: .45rem;
  right: .45rem;
  background: rgba(255,255,255,.1);
  border: 1px solid rgba(255,255,255,.2);
  border-radius: 4px;
  color: rgba(255,255,255,.65);
  font-size: .68rem;
  padding: .18rem .5rem;
  cursor: pointer;
  transition: background .15s;
}
.copy-btn:hover { background: rgba(255,255,255,.2); color: #fff; }

/* Evidence items */
.ev-item {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: .75rem 1rem;
  margin-bottom: .55rem;
  transition: border-color .15s;
}
.ev-item:hover { border-color: var(--border-md); }
.ev-top-row {
  display: flex;
  align-items: center;
  gap: .5rem;
  flex-wrap: wrap;
  margin-bottom: .3rem;
}
.ev-type-badge {
  font-size: .63rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .05em;
  padding: .12rem .45rem;
  border-radius: 3px;
}
.ev-type-signal { background: #DBEAFE; color: #1E40AF; }
.ev-type-log    { background: #D1FAE5; color: #065F46; }
.ev-type-git    { background: #FEF3C7; color: #92400E; }
.ev-source-label {
  font-size: .72rem;
  color: var(--text-muted);
  font-family: var(--mono);
}
.ev-kind-label {
  font-size: .72rem;
  font-weight: 600;
  color: var(--navy);
}
.ev-sep { color: var(--text-light); font-size: .7rem; }
.ev-target {
  font-size: .7rem;
  font-family: var(--mono);
  color: var(--text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}
.ev-message {
  font-size: .78rem;
  color: var(--text);
  line-height: 1.45;
  margin-top: .2rem;
  padding-top: .2rem;
  border-top: 1px solid var(--border);
}
.ev-counts { display: flex; gap: .75rem; margin-top: .25rem; }
.ev-before { font-size: .7rem; color: var(--critical); font-weight: 600; }
.ev-after  { font-size: .7rem; color: var(--low);      font-weight: 600; }

/* ── HEALTHY STATE ──────────────────────────────────────────────────────── */
.healthy-card {
  text-align: center;
  padding: 3.5rem 2rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
}
.healthy-icon { font-size: 3.5rem; margin-bottom: .75rem; }
.healthy-title { font-size: 1.3rem; font-weight: 800; color: var(--low); margin-bottom: .5rem; }
.healthy-desc { color: var(--text-muted); max-width: 380px; margin: 0 auto; font-size: .9rem; }

/* ── FOOTER ─────────────────────────────────────────────────────────────── */
.report-footer {
  background: var(--navy);
  color: rgba(255,255,255,.45);
  padding: 1.5rem 2rem;
  margin-top: 3rem;
  font-size: .78rem;
  text-align: center;
  line-height: 1.8;
}
.report-footer strong { color: rgba(255,255,255,.8); }
.report-footer a { color: rgba(255,255,255,.55); text-decoration: none; }
.report-footer a:hover { color: #fff; }
</style>
</head>
<body>

{# ── HEADER ──────────────────────────────────────────────────────────────── #}
<header class="report-header">
  <div class="header-top">
    <div class="brand">
      <div class="brand-logo">
        {% if logo_uri %}<img src="{{ logo_uri }}" alt="PerfSage">{% else %}⚡{% endif %}
      </div>
      <div class="brand-text-wrap">
        <div class="brand-eyebrow">PerfSage · SignalPilot</div>
        <div class="report-title">Root Cause Analysis Report</div>
      </div>
    </div>
    <div class="header-meta-block">
      <div>Namespace&nbsp; <strong>{{ analysis.namespace }}</strong></div>
      <div>Generated&nbsp; <strong>{{ generated_at }}</strong></div>
      <div>Analysis&nbsp; <strong>{{ analysis.id[:12] }}</strong>
        {% if analysis.duration_s %}&nbsp;·&nbsp;<strong>{{ "%.1f"|format(analysis.duration_s) }}s</strong>{% endif %}
      </div>
    </div>
  </div>

  <div class="header-pills">
    <span class="pill-label">Severity</span>
    {% if sev_counts.critical > 0 %}
    <span class="sev-pill"><span class="dot dot-critical"></span>{{ sev_counts.critical }} Critical</span>
    {% endif %}
    {% if sev_counts.high > 0 %}
    <span class="sev-pill"><span class="dot dot-high"></span>{{ sev_counts.high }} High</span>
    {% endif %}
    {% if sev_counts.medium > 0 %}
    <span class="sev-pill"><span class="dot dot-medium"></span>{{ sev_counts.medium }} Medium</span>
    {% endif %}
    {% if sev_counts.low > 0 %}
    <span class="sev-pill"><span class="dot dot-low"></span>{{ sev_counts.low }} Low</span>
    {% endif %}
    {% if not findings %}
    <span class="sev-pill"><span class="dot dot-low"></span>All Clear</span>
    {% endif %}

    {% if analysis.sources_used %}
    <div class="sources-wrap">
      <span class="pill-label">Sources</span>
      {% for src in analysis.sources_used %}
      <span class="src-pill">{{ src | source_label }}</span>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</header>

{# ── MAIN ────────────────────────────────────────────────────────────────── #}
<main class="container">

  {# Alert banner — top finding or healthy #}
  {% if findings %}
    {% set top = findings[0] %}
    {% set css = top.severity | severity_css %}
  <div class="alert-banner {{ css }}">
    <div class="alert-icon">
      {% if css == 'critical' %}🚨{% elif css == 'high' %}⚠️{% elif css == 'medium' %}🔶{% else %}🔵{% endif %}
    </div>
    <div class="alert-body">
      <div class="alert-label {{ css }}">Top Finding — {{ css | upper }}</div>
      <div class="alert-headline">{{ top.title }}</div>
      <div class="alert-desc">{{ top.explanation[:220] }}{% if top.explanation | length > 220 %}…{% endif %}</div>
    </div>
  </div>
  {% else %}
  <div class="alert-banner healthy">
    <div class="alert-icon">✅</div>
    <div class="alert-body">
      <div class="alert-label healthy">System Healthy</div>
      <div class="alert-headline">No significant issues detected</div>
      <div class="alert-desc">All signals analysed — this deployment appears healthy across all monitored dimensions.</div>
    </div>
  </div>
  {% endif %}

  {# KPI grid #}
  <div class="kpi-grid">
    <div class="kpi-card">
      <div class="kpi-icon">🚨</div>
      <div class="kpi-num c-critical">{{ sev_counts.critical }}</div>
      <div class="kpi-label">Critical</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon">⚠️</div>
      <div class="kpi-num c-high">{{ sev_counts.high }}</div>
      <div class="kpi-label">High</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon">🔶</div>
      <div class="kpi-num c-medium">{{ sev_counts.medium }}</div>
      <div class="kpi-label">Medium</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon">🔍</div>
      <div class="kpi-num c-navy">{{ findings | length }}</div>
      <div class="kpi-label">Total Findings</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon">📡</div>
      <div class="kpi-num c-purple">{{ analysis.sources_used | length }}</div>
      <div class="kpi-label">Data Sources</div>
    </div>
  </div>

  {# Narrative #}
  {% if analysis.narrative %}
  <div class="narrative-card">
    {% for para in analysis.narrative.split('\n\n') %}
    <p>{{ para }}</p>
    {% endfor %}
  </div>
  {% endif %}

  {# Deploy change #}
  {% if deploy_change %}
  <div class="section-heading">🚀 Deployment Change</div>
  <div class="deploy-card">
    <div class="deploy-header-row">
      <span class="deploy-name-badge">{{ deploy_change.deployment }}</span>
      <span class="deploy-rev-range">
        rev <strong>{{ deploy_change.from_revision or '?' }}</strong>
        &nbsp;→&nbsp;
        rev <strong>{{ deploy_change.to_revision }}</strong>
      </span>
    </div>

    {% for d in deploy_change.image_diffs %}
    <div class="diff-grid">
      <div class="diff-cell diff-before">
        <div class="diff-field-label">Image Before</div>
        {{ d.from_image or 'none' }}
      </div>
      <div class="diff-cell diff-after">
        <div class="diff-field-label">Image After</div>
        {{ d.to_image }}
      </div>
    </div>
    {% endfor %}

    {% for k, v in deploy_change.env_diff.items() %}
    <div class="diff-grid">
      <div class="diff-cell diff-before">
        <div class="diff-field-label">Env {{ k }} — Before</div>
        {{ v[0] or 'none' }}
      </div>
      <div class="diff-cell diff-after">
        <div class="diff-field-label">Env {{ k }} — After</div>
        {{ v[1] or 'removed' }}
      </div>
    </div>
    {% endfor %}

    {% if deploy_change.git and deploy_change.git.suspect_commits %}
    <div style="margin-top:.75rem">
      {% for c in deploy_change.git.suspect_commits %}
      <div class="commit-row">
        <span class="commit-sha">{{ c.sha[:8] }}</span>
        <div>
          <div class="commit-msg">{{ c.message[:120] }}</div>
          <div class="commit-author">by {{ c.author }}</div>
        </div>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endif %}

  {# ── FINDINGS ─────────────────────────────────────────────────────────── #}
  {% if not findings %}
  <div class="healthy-card">
    <div class="healthy-icon">✅</div>
    <div class="healthy-title">Deployment Healthy</div>
    <div class="healthy-desc">No significant anomalies found across {{ analysis.sources_used | length }} data source(s). Keep monitoring.</div>
  </div>
  {% else %}
  <div class="section-heading">🔍 Findings ({{ findings | length }})</div>

  {% for finding in findings %}
  {% set css = finding.severity | severity_css %}
  <div class="finding-card sev-{{ css }}" id="finding-{{ loop.index }}">

    {# ← Collapsible header #}
    <div class="finding-header" onclick="toggleFinding(this)">
      <span class="sev-badge {{ css }}">{{ css }}</span>
      <div class="finding-title-wrap">
        <div class="finding-title">{{ finding.title }}</div>
        <div class="finding-target-line">
          {{ finding.target.kind }}/{{ finding.target.name }}{% if finding.target.container %}/{{ finding.target.container }}{% endif %}
          &nbsp;·&nbsp;rule: {{ finding.rule_id }}
        </div>
      </div>
      <div class="finding-right">
        <div class="conf-wrap">
          <div class="conf-bar-outer">
            <div class="conf-bar-inner" style="width:{{ (finding.confidence * 100) | int }}%"></div>
          </div>
          <div class="conf-pct">{{ finding.confidence | pct }}</div>
          <div class="conf-label">Confidence</div>
        </div>
        <div class="chevron{% if loop.first %} open{% endif %}">▼</div>
      </div>
    </div>

    {# Body #}
    <div class="finding-body{% if loop.first %} open{% endif %}">
      <div class="finding-body-inner">

        <div class="explanation-block">{{ finding.explanation }}</div>

        <div class="finding-cols">

          {# FIXES #}
          <div>
            <div class="col-title">🔧 Recommended Fixes</div>
            {% if finding.fixes %}
            {% for fix in finding.fixes %}
            <div class="fix-item">
              <div class="fix-step-row">
                <span class="fix-num">{{ loop.index }}</span>
                <span class="fix-desc">{{ fix.description }}</span>
              </div>
              {% if fix.current_value %}
              <div class="fix-change-row">
                <span class="val-before">{{ fix.current_value }}</span>
                <span class="val-arrow">→</span>
                <span class="val-after">{{ fix.proposed_value or '?' }}</span>
              </div>
              {% endif %}
              {% if fix.kubectl_snippet %}
              <div class="fix-code-wrap">
                <pre class="fix-code">{{ fix.kubectl_snippet }}</pre>
                <button class="copy-btn" onclick="copyCode(this)">copy</button>
              </div>
              {% endif %}
              {% if fix.yaml_snippet %}
              <div class="fix-code-wrap">
                <pre class="fix-code">{{ fix.yaml_snippet }}</pre>
                <button class="copy-btn" onclick="copyCode(this)">copy</button>
              </div>
              {% endif %}
              {% if fix.expected_improvement %}
              <div style="font-size:.75rem;color:var(--low);margin-top:.4rem;">
                ✓ {{ fix.expected_improvement }}
              </div>
              {% endif %}
            </div>
            {% endfor %}
            {% else %}
            <div style="font-size:.85rem;color:var(--text-muted);padding:.5rem 0;">
              No automated fixes available — see explanation above.
            </div>
            {% endif %}
          </div>

          {# EVIDENCE #}
          <div>
            <div class="col-title">📊 Supporting Evidence ({{ finding.evidence | length }})</div>
            {% if finding.evidence %}
            {% for ev in finding.evidence %}
            <div class="ev-item">
              {% if ev.type == 'signal' %}
              <div class="ev-top-row">
                <span class="ev-type-badge ev-type-signal">Signal</span>
                <span class="ev-kind-label">{{ ev.kind | kind_icon }} {{ ev.kind | kind_label }}</span>
                <span class="ev-sep">·</span>
                <span class="ev-source-label">{{ ev.source | source_label }}</span>
              </div>
              <div class="ev-target">
                {{ ev.target.kind }}/{{ ev.target.name }}{% if ev.target.container %}/{{ ev.target.container }}{% endif %}
              </div>
              {% if ev.message %}
              <div class="ev-message">{{ ev.message[:160] }}{% if ev.message | length > 160 %}…{% endif %}</div>
              {% endif %}

              {% elif ev.type == 'log_cluster' %}
              <div class="ev-top-row">
                <span class="ev-type-badge ev-type-log">Log Pattern</span>
                {% if ev.is_new %}<span style="font-size:.65rem;font-weight:800;color:var(--critical);text-transform:uppercase;letter-spacing:.05em;">NEW</span>{% endif %}
              </div>
              <div class="ev-message" style="font-family:var(--mono);">&ldquo;{{ ev.template[:140] }}{% if ev.template | length > 140 %}…{% endif %}&rdquo;</div>
              <div class="ev-counts">
                <span class="ev-before">Before: {{ ev.count_before }}</span>
                <span class="ev-after">After: {{ ev.count_after }}</span>
              </div>

              {% elif ev.type == 'git_change' %}
              <div class="ev-top-row">
                <span class="ev-type-badge ev-type-git">Git</span>
                <span class="ev-source-label">{{ ev.from_sha[:8] if ev.from_sha else '?' }} → {{ ev.to_sha[:8] }}</span>
              </div>
              <div style="font-size:.78rem;color:var(--text-muted);">{{ ev.commits | length }} commit(s) in window</div>

              {% else %}
              <div class="ev-message">{{ ev }}</div>
              {% endif %}
            </div>
            {% endfor %}
            {% else %}
            <div style="font-size:.85rem;color:var(--text-muted);padding:.5rem 0;">
              No structured evidence captured.
            </div>
            {% endif %}
          </div>

        </div>{# /finding-cols #}
      </div>{# /body-inner #}
    </div>{# /body #}
  </div>{# /finding-card #}
  {% endfor %}
  {% endif %}

</main>

{# ── FOOTER ──────────────────────────────────────────────────────────────── #}
<footer class="report-footer">
  <strong>PerfSage SignalPilot</strong> · AI-powered Kubernetes root cause analysis ·
  <a href="https://perfsage.com" target="_blank">perfsage.com</a><br>
  Report generated {{ generated_at }} · Analysis <code style="color:rgba(255,255,255,.55)">{{ analysis.id[:12] }}</code>
</footer>

<script>
function toggleFinding(header) {
  const body = header.nextElementSibling;
  const chevron = header.querySelector('.chevron');
  const isOpen = body.classList.contains('open');
  body.classList.toggle('open', !isOpen);
  if (chevron) chevron.classList.toggle('open', !isOpen);
}

function copyCode(btn) {
  const pre = btn.previousElementSibling;
  if (!pre) return;
  navigator.clipboard.writeText(pre.textContent.trim()).then(() => {
    btn.textContent = 'copied!';
    setTimeout(() => { btn.textContent = 'copy'; }, 2000);
  }).catch(() => {
    // Fallback for older browsers
    const ta = document.createElement('textarea');
    ta.value = pre.textContent.trim();
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    btn.textContent = 'copied!';
    setTimeout(() => { btn.textContent = 'copy'; }, 2000);
  });
}
</script>
</body>
</html>
